{
  "expo": {
    "name": "KingfoodWMS",
    "slug": "KingfoodWMS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kingfoodwms",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "permissions": ["android.permission.CAMERA"]
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
          [
        "expo-camera",
        {
            "cameraPermission": "Ứng dụng cần quyền camera để quét mã barcode sản phẩm"
        }
    ],
    ["expo-camera", {
        "cameraPermission": "Cần quyền camera để quét mã barcode"
    }],
    ["expo-image-picker", {
        "cameraPermission": "Cần quyền camera để chụp ảnh minh chứng"
    }],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
